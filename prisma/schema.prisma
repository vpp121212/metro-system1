generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./traineye.db"
}

model Line {
  id        String   @id @default(uuid())
  nameAr    String
  nameEn    String
  color     String
  colorHex  String
  order     Int
  stations  Station[]
  trains    Train[]
  trips     Trip[]
  alerts    Alert[]
  passengerRecords PassengerRecord[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Station {
  id            String   @id @default(uuid())
  nameAr        String
  nameEn        String
  lineId        String
  line          Line     @relation(fields: [lineId], references: [id])
  order         Int
  lat           Float
  lng           Float
  isInterchange Boolean  @default(false)
  trains        Train[]
  alerts        Alert[]
  cameras       Camera[]
  tripsFrom     Trip[]   @relation("FromStation")
  tripsTo       Trip[]   @relation("ToStation")
  passengerRecords PassengerRecord[]
  managers      User[]   @relation("StationManagers")
  incidentReports IncidentReport[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([lineId])
}

model Train {
  id              String   @id @default(uuid())
  name            String
  code            String   @unique
  lineId          String
  line            Line     @relation(fields: [lineId], references: [id])
  status          String   @default("ACTIVE")
  speed           Float    @default(0)
  direction       String   @default("forward")
  currentStationId String?
  currentStation  Station? @relation(fields: [currentStationId], references: [id])
  capacity        Int      @default(1000)
  passengerCount  Int      @default(0)
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  trips           Trip[]
  maintenanceRecords MaintenanceRecord[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([lineId])
  @@index([status])
}

model Trip {
  id             String   @id @default(uuid())
  trainId        String
  train          Train    @relation(fields: [trainId], references: [id])
  lineId         String
  line           Line     @relation(fields: [lineId], references: [id])
  fromStationId  String
  fromStation    Station  @relation("FromStation", fields: [fromStationId], references: [id])
  toStationId    String
  toStation      Station  @relation("ToStation", fields: [toStationId], references: [id])
  status         String   @default("SCHEDULED")
  scheduledAt    DateTime
  actualStartAt  DateTime?
  actualEndAt    DateTime?
  delayMinutes   Int      @default(0)
  passengerCount Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([trainId])
  @@index([lineId])
  @@index([status])
}

model Camera {
  id        String   @id @default(uuid())
  name      String
  stationId String
  station   Station  @relation(fields: [stationId], references: [id])
  status    String   @default("ACTIVE")
  streamUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stationId])
}

model Alert {
  id             String   @id @default(uuid())
  type           String
  titleAr        String
  titleEn        String
  descriptionAr  String
  descriptionEn  String
  stationId      String?
  station        Station? @relation(fields: [stationId], references: [id])
  lineId         String?
  line           Line?    @relation(fields: [lineId], references: [id])
  isAcknowledged Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type])
  @@index([stationId])
  @@index([lineId])
}

model PassengerRecord {
  id             String   @id @default(uuid())
  stationId      String
  station        Station  @relation(fields: [stationId], references: [id])
  lineId         String
  line           Line     @relation(fields: [lineId], references: [id])
  count          Int
  densityPercent Float    @default(0)
  timestamp      DateTime @default(now())

  @@index([stationId])
  @@index([lineId])
  @@index([timestamp])
}

model MaintenanceRecord {
  id          String   @id @default(uuid())
  trainId     String
  train       Train    @relation(fields: [trainId], references: [id])
  type        String
  description String
  status      String   @default("SCHEDULED")
  scheduledAt DateTime
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([trainId])
  @@index([status])
}

model Fleet {
  id          String   @id @default(uuid())
  name        String
  total       Int      @default(0)
  active      Int      @default(0)
  maintenance Int      @default(0)
  available   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id          String   @id @default(uuid())
  employeeId  String   @unique
  name        String
  email       String   @unique
  password    String
  roleId      String
  role        Role     @relation(fields: [roleId], references: [id])
  stationId   String?
  station     Station? @relation("StationManagers", fields: [stationId], references: [id])
  avatar      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  incidentReports      IncidentReport[] @relation("ReportedBy")
  assignedIncidents    IncidentReport[] @relation("AssignedTo")

  @@index([roleId])
  @@index([employeeId])
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(uuid())
  name      String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())

  @@index([roleId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String?
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemHealth {
  id            String   @id @default(uuid())
  healthPercent Float    @default(99.5)
  uptimeSeconds Int      @default(0)
  timestamp     DateTime @default(now())

  @@index([timestamp])
}

model IncidentReport {
  id          String   @id @default(uuid())
  type        String
  description String
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  stationId   String?
  station     Station? @relation(fields: [stationId], references: [id])
  reportedById String?
  reportedBy  User?    @relation("ReportedBy", fields: [reportedById], references: [id])
  assignedToId String?
  assignedTo  User?    @relation("AssignedTo", fields: [assignedToId], references: [id])
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([stationId])
  @@index([status])
  @@index([type])
}

model ChatMessage {
  id        String   @id @default(uuid())
  role      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([role])
}
